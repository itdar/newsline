#!/usr/bin/env bash
# newsline — single CLI entrypoint for the local news status-line utility.
#
#   newsline init        interactive setup: language, topic, status-line wiring.
#                        COMPOSES with an existing status line (e.g. your HUD),
#                        so rate-limit / context info stays visible.
#   newsline color [c]   set the headline color (or cycle to the next when no name).
#   newsline colorlist   list the available headline colors with a live preview.
#   newsline render      what settings.json runs each refresh (base HUD + news).
#   newsline refresh     force a cache refresh now.
#   newsline once        fetch + print headlines once (debug).
#   newsline uninstall   remove the wiring, restore what was there.
#   newsline help
#
# Test overrides: NEWSLINE_SETTINGS, NEWSLINE_CONFIG_DIR, NEWSLINE_CACHE.
set -u

# resolve our real dir even when invoked via a PATH symlink (so helpers are found)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
HERE="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
CONFIG_DIR="${NEWSLINE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/newsline}"
CONFIG="$CONFIG_DIR/config.json"
SETTINGS="${NEWSLINE_SETTINGS:-$HOME/.claude/settings.json}"

# Command written into settings.json. ALWAYS an absolute path — Claude Code runs
# the status line in a non-login shell whose PATH may not include ~/.local/bin.
NL_BIN="$(command -v newsline 2>/dev/null || echo "$HERE/newsline")"
RENDER_CMD="\"$NL_BIN\" render"

# ---- tiny JSON helpers (python; no jq dependency) ----
cfg_get() { # cfg_get <key>
  python3 - "$CONFIG" "$1" <<'PY' 2>/dev/null
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: d={}
v=d.get(sys.argv[2])
print("" if v is None else v)
PY
}
cfg_get_obj() { # cfg_get_obj <key> — print an object-valued config key as JSON
  python3 - "$CONFIG" "$1" <<'PY' 2>/dev/null
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: d={}
v=d.get(sys.argv[2])
print(json.dumps(v,ensure_ascii=False) if isinstance(v,dict) else "")
PY
}
settings_statusline_cmd() { # print current statusLine.command of a settings file
  python3 - "$1" <<'PY' 2>/dev/null
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: d={}
sl=d.get("statusLine")
print(sl.get("command","") if isinstance(sl,dict) else "")
PY
}
settings_statusline_json() { # print the whole statusLine object of a settings file
  python3 - "$1" <<'PY' 2>/dev/null
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: d={}
sl=d.get("statusLine")
print(json.dumps(sl,ensure_ascii=False) if isinstance(sl,dict) and sl.get("command") else "")
PY
}

# One python spawn for the whole config (render runs on every status-line tick;
# per-key cfg_get calls here would cost ~10 interpreter startups per tick).
load_config() {
  [ -f "$CONFIG" ] || return 0
  local exports
  exports=$(python3 - "$CONFIG" <<'PY' 2>/dev/null
import json,sys,shlex
env={"lang":"NEWSLINE_LANG","topic":"NEWSLINE_TOPIC","rotate":"NEWSLINE_ROTATE",
     "count":"NEWSLINE_COUNT","maxlen":"NEWSLINE_MAXLEN","icon":"NEWSLINE_ICON",
     "color":"NEWSLINE_COLOR","linkhint":"NEWSLINE_LINKHINT","api":"NEWSLINE_API",
     "endpoint":"NEWSLINE_ENDPOINT","base_statusline":"NEWSLINE_BASE"}
try: d=json.load(open(sys.argv[1]))
except Exception: d={}
for k,name in env.items():
    v=d.get(k)
    if v is None or v=="": continue
    if k=="lang" and v=="auto": continue
    print("export %s=%s" % (name, shlex.quote(str(v))))
PY
)
  [ -n "$exports" ] && eval "$exports"
}

detect_lang() {
  local raw="${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}"
  if command -v defaults >/dev/null 2>&1; then
    raw="$(defaults read NSGlobalDomain AppleLocale 2>/dev/null || echo "$raw")"
  fi
  raw="${raw%%.*}"; raw="${raw%%@*}"; local l="${raw%%_*}"; l="${l%%-*}"
  echo "${l:-en}"
}

lang_label() {  # code -> native (English) display name
  case "$1" in
    ko) echo "한국어 (Korean)" ;;        ja) echo "日本語 (Japanese)" ;;
    en) echo "English" ;;                 es) echo "Español (Spanish)" ;;
    fr) echo "Français (French)" ;;       de) echo "Deutsch (German)" ;;
    pt) echo "Português (Portuguese)" ;;  zh) echo "中文 (Chinese)" ;;
    *)  echo "$1" ;;
  esac
}

# choose <default_code> <code1> <label1> <code2> <label2> ...  -> sets $CHOICE
CHOICE=""
choose() {
  local def="$1"; shift
  local -a codes=() labels=()
  while [ $# -gt 0 ]; do codes+=("$1"); labels+=("${2:-$1}"); shift 2; done
  local i defnum=1
  for i in "${!codes[@]}"; do
    [ "${codes[$i]}" = "$def" ] && defnum=$((i + 1))
    printf "  %2d) %s\n" "$((i + 1))" "${labels[$i]}" >&2
  done
  printf "  # [%d]: " "$defnum" >&2
  local sel; read -r sel < "${NL_TTY:-/dev/stdin}"
  case "$sel" in ''|*[!0-9]*) sel="$defnum" ;; esac
  if [ "$sel" -ge 1 ] 2>/dev/null && [ "$sel" -le "${#codes[@]}" ] 2>/dev/null; then
    CHOICE="${codes[$((sel - 1))]}"
  else
    CHOICE="$def"
  fi
}

# ---- subcommands ----
cmd_render() { # base (existing HUD) first, newsline below — never blocks
  load_config
  local input=""
  [ -t 0 ] || input=$(cat 2>/dev/null)     # consume the session JSON if piped
  if [ -n "${NEWSLINE_BASE:-}" ]; then
    printf '%s' "$input" | eval "$NEWSLINE_BASE" 2>/dev/null   # your HUD, unchanged
    printf '\n'
  fi
  "$HERE/statusline.sh"                                # the news line, below
}

cmd_refresh() { load_config; "$HERE/refresh.sh"; }

cmd_once() {
  load_config; "$HERE/refresh.sh"
  local dir="${NEWSLINE_CACHE:-$HOME/.cache/newsline}"
  [ -s "$dir/line" ] && cat "$dir/line" && echo
}

cmd_init() {
  local lang="" topic="" color="" api="" endpoint="" rotate="6" count="15" compose="auto" yes="0" base_override="" a
  while [ $# -gt 0 ]; do
    case "$1" in
      --lang) lang="$2"; shift 2;;      --topic) topic="$2"; shift 2;;
      --api) api="$2"; shift 2;;        --endpoint) endpoint="$2"; shift 2;;
      --rotate) rotate="$2"; shift 2;;  --count) count="$2"; shift 2;;
      --base) base_override="$2"; shift 2;;
      --compose) compose="yes"; shift;; --no-compose) compose="no"; shift;;
      --settings) SETTINGS="$2"; shift 2;; --yes|-y) yes="1"; shift;;
      *) shift;;
    esac
  done

  local detected; detected=$(detect_lang)
  # Interactive input source: stdin if it's a tty, else the controlling terminal
  # (/dev/tty) — this lets `curl … | sh` still prompt the user.
  NL_TTY=""
  if [ "$yes" = "0" ]; then
    if [ "${NEWSLINE_FORCE_TTY:-}" = "1" ] || [ -t 0 ]; then NL_TTY=/dev/stdin
    elif [ -r /dev/tty ]; then NL_TTY=/dev/tty; fi
  fi
  if [ -n "$NL_TTY" ]; then
    if [ -z "$lang" ]; then
      # languages that actually have bundled feeds, offered as a numbered menu
      local avail c; local -a menu=(auto "Auto-detect (now: $(lang_label "$detected"))")
      avail=$(python3 -c "import json,sys;d=json.load(open(sys.argv[1]));print(' '.join(k for k in d if k not in ('default','_comment')))" "$HERE/feeds.json" 2>/dev/null)
      for c in $avail; do menu+=("$c" "$(lang_label "$c")"); done
      echo "Select news language:" >&2
      choose "$detected" "${menu[@]}"; lang="$CHOICE"
    fi
    if [ -z "$topic" ]; then
      echo "Select topic:" >&2
      choose general \
        general "General" tech "Tech" business "Business" world "World" \
        sports "Sports" science "Science" health "Health" entertainment "Entertainment"
      topic="$CHOICE"
    fi
    local cur_color; cur_color=$(cfg_get color)
    echo "Select headline color (change anytime: newsline color):" >&2
    choose "${cur_color:-magenta}" \
      default "Terminal default" cyan "Cyan" gray "Gray" white "White" \
      yellow "Yellow" green "Green" blue "Blue" magenta "Magenta" red "Red"
    color="$CHOICE"
  else
    # --yes: keep a color previously set via init/`newsline color`; magenta on first run
    lang="${lang:-$detected}"; topic="${topic:-general}"
    color=$(cfg_get color); [ -n "$color" ] || color="magenta"
  fi

  # Always KEEP an existing status line and show newsline below it (no prompt).
  # Only --no-compose (or an explicit --base) changes this.
  local existing base="" base_obj=""
  if [ -n "$base_override" ]; then
    base="$base_override"                       # caller supplied the base explicitly
  elif [ "$compose" != "no" ]; then
    existing=$(settings_statusline_cmd "$SETTINGS")
    if [ -n "$existing" ] && ! printf '%s' "$existing" | grep -q "newsline"; then
      base="$existing"                          # first run: capture the real status line
      base_obj=$(settings_statusline_json "$SETTINGS")   # verbatim, for uninstall
    else
      base=$(cfg_get base_statusline)           # re-init: KEEP the base we already saved
      base_obj=$(cfg_get_obj base_statusline_obj)
    fi
  fi

  mkdir -p "$CONFIG_DIR"
  python3 - "$CONFIG" "$lang" "$topic" "$rotate" "$count" "$api" "$endpoint" "$base" "$base_obj" "$color" <<'PY' || { echo "✗ could not write $CONFIG" >&2; return 1; }
import json,os,sys
_,path,lang,topic,rotate,count,api,endpoint,base,base_obj,color=sys.argv
try:
    d={"lang":lang,"topic":topic,"rotate":int(rotate),"count":int(count)}
except ValueError:
    sys.stderr.write("newsline: --rotate/--count must be integers\n"); sys.exit(3)
if color and color not in ("default","none","off"): d["color"]=color
if api: d["api"]=api
if endpoint: d["endpoint"]=endpoint
if base: d["base_statusline"]=base
if base_obj:
    try: d["base_statusline_obj"]=json.loads(base_obj)
    except Exception: pass
tmp=path+".tmp"
with open(tmp,"w") as f: json.dump(d,f,indent=2,ensure_ascii=False)
os.replace(tmp,path)
PY

  python3 - "$SETTINGS" "$RENDER_CMD" <<'PY' || { echo "✗ could not update $SETTINGS — fix the file and re-run: newsline init" >&2; return 1; }
import json,os,sys
path,cmd=sys.argv[1],sys.argv[2]
d={}
if os.path.exists(path):
    try:
        with open(path) as f: raw=f.read().strip()
        d=json.loads(raw) if raw else {}
        if not isinstance(d,dict): raise ValueError("settings root is not an object")
    except Exception:
        # never clobber a settings file we can't parse
        sys.stderr.write("newsline: %s is not valid JSON; refusing to modify it\n" % path)
        sys.exit(3)
d["statusLine"]={"type":"command","command":cmd,"refreshInterval":5}
os.makedirs(os.path.dirname(path) or ".",exist_ok=True)
tmp=path+".tmp"
with open(tmp,"w") as f: json.dump(d,f,indent=2,ensure_ascii=False)
os.replace(tmp,path)
PY

  # apply the new language/topic on the next render, not after the old cache expires
  local cache="${NEWSLINE_CACHE:-$HOME/.cache/newsline}"
  rm -f "$cache/line" "$cache/feeds.resolved.json" "$cache/feeds.resolved.ok" "$cache/notice" 2>/dev/null

  echo "✔ newsline installed (lang=$lang, topic=$topic)."
  [ -n "$base" ] && echo "  composing with your existing status line — it stays visible above the news."
  echo "  It appears on your next message to Claude — no restart needed."
}

# canonical headline palette — single source of truth for cycling, listing, and
# validation. "default" means the terminal's own color (no SGR); the rest map to
# the SGR codes in statusline.sh (nl_sgr below mirrors that mapping).
NL_PALETTE="default gray white cyan yellow green blue magenta red"

nl_sgr() { # color name -> SGR params (empty = terminal default). Mirrors statusline.sh.
  case "$1" in
    dim)        echo "2"  ;;
    gray|grey)  echo "90" ;;
    red)        echo "31" ;;  green)   echo "32" ;;  yellow) echo "33" ;;
    blue)       echo "34" ;;  magenta) echo "35" ;;  cyan)   echo "36" ;;
    white)      echo "37" ;;  orange)  echo "38;5;208" ;;
    *)          echo ""   ;;
  esac
}

nl_write_color() { # nl_write_color <name> — persist the chosen color to config
  mkdir -p "$CONFIG_DIR"
  python3 - "$CONFIG" "$1" <<'PY' || { echo "✗ could not write $CONFIG" >&2; return 1; }
import json,os,sys
path,color=sys.argv[1],sys.argv[2]
try: d=json.load(open(path))
except Exception: d={}
if color in ("default","none","off"): d.pop("color",None)
else: d["color"]=color
tmp=path+".tmp"
with open(tmp,"w") as f: json.dump(d,f,indent=2,ensure_ascii=False)
os.replace(tmp,path)
PY
}

cmd_colorlist() { # newsline colorlist — list the palette, each shown in its own color
  local cur c sgr mark; cur=$(cfg_get color); [ -n "$cur" ] || cur=default
  echo "Headline colors (set with: newsline color <name>):"
  for c in $NL_PALETTE; do
    [ "$c" = "$cur" ] && mark="  ← current" || mark=""
    sgr=$(nl_sgr "$c")
    if [ -n "$sgr" ]; then
      printf '  \033[%sm%-8s 📰 sample headline\033[0m%s\n' "$sgr" "$c" "$mark"
    else
      printf '  %-8s 📰 sample headline%s\n' "$c" "$mark"
    fi
  done
}

cmd_color() { # newsline color [name] — set a color; with no name, step to the next one
  local cur new arg; arg="${1:-}"
  case "$arg" in list|ls|--list) cmd_colorlist; return $? ;; esac
  if [ -n "$arg" ]; then
    new="$(printf '%s' "$arg" | tr '[:upper:]' '[:lower:]')"
    case "$new" in grey) new=gray ;; none|off) new=default ;; esac
    case " $NL_PALETTE " in
      *" $new "*) ;;
      *) echo "✗ unknown color: $arg" >&2
         echo "  choose from: $NL_PALETTE   (see: newsline colorlist)" >&2
         return 1 ;;
    esac
  else                                   # no name: cycle to the next color, wrapping
    cur=$(cfg_get color)
    new=$(NL_PALETTE="$NL_PALETTE" python3 - "${cur:-default}" <<'PY'
import os,sys
p=os.environ["NL_PALETTE"].split()
c=sys.argv[1]
print(p[(p.index(c)+1)%len(p)] if c in p else p[0])
PY
)
  fi
  nl_write_color "$new" || return 1
  echo "✔ headline color: $new — preview:"
  load_config
  "$HERE/statusline.sh"; echo
}

cmd_uninstall() {
  local base base_obj
  base=$(cfg_get base_statusline)
  base_obj=$(cfg_get_obj base_statusline_obj)
  python3 - "$SETTINGS" "$base" "$base_obj" <<'PY'
import json,os,sys
path,base,base_obj=sys.argv[1],sys.argv[2],sys.argv[3]
try:
    with open(path) as f: raw=f.read().strip()
    d=json.loads(raw) if raw else {}
    if not isinstance(d,dict): raise ValueError("settings root is not an object")
except FileNotFoundError:
    print("no settings file; nothing to revert"); sys.exit(0)
except Exception:
    print("settings file is not valid JSON; left as-is"); sys.exit(0)
sl=d.get("statusLine"); cmd=sl.get("command","") if isinstance(sl,dict) else ""
if "newsline" in cmd:
    obj=None
    if base_obj:
        try: obj=json.loads(base_obj)
        except Exception: obj=None
    if isinstance(obj,dict) and obj.get("command"):
        d["statusLine"]=obj                    # full original (keeps padding etc.)
    elif base:
        d["statusLine"]={"type":"command","command":base}
    else:
        d.pop("statusLine",None)
    tmp=path+".tmp"
    with open(tmp,"w") as f: json.dump(d,f,indent=2,ensure_ascii=False)
    os.replace(tmp,path)
    print("reverted status line")
else:
    print("status line not managed by newsline; left as-is")
PY
  local cache="${NEWSLINE_CACHE:-$HOME/.cache/newsline}"
  rm -f "$CONFIG" "$cache/line" "$cache/feeds.resolved.json" "$cache/feeds.resolved.ok" "$cache/notice" 2>/dev/null
  echo "✔ newsline uninstalled."
}

usage() {
  cat <<'EOF'
newsline — local news status-line utility
  newsline init [--lang ko] [--topic tech]    set up & wire the status line
                                              (asks language / topic / color)
  newsline color [name]                       set headline color (e.g. cyan, gray); with
                                              no name, step to the next: default → gray →
                                              white → cyan → yellow → green → blue →
                                              magenta → red → back to default
  newsline colorlist                          list the available colors with a preview
  newsline uninstall                          remove & restore previous status line
EOF
  if [ "${1:-}" = "--all" ]; then
    cat <<'EOF'

internal (Claude Code calls these automatically; for debugging only):
  newsline render      draw the status line now (HUD + news)
  newsline refresh     force a cache refresh
  newsline once        fetch + print headlines once
EOF
  fi
}

case "${1:-help}" in
  render) shift; cmd_render "$@";;
  refresh) shift; cmd_refresh "$@";;
  once) shift; cmd_once "$@";;
  init) shift; cmd_init "$@";;
  color) shift; cmd_color "$@";;
  colorlist|colors) shift; cmd_colorlist;;
  uninstall) shift; cmd_uninstall "$@";;
  help|-h|--help) shift; usage "$@";;
  *) usage; exit 1;;
esac
